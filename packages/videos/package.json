{
  "name": "videos",
  "version": "0.0.0",
  "private": true,
  "description": "Remotion videos for Batchwork — launch and marketing motion.",
  "license": "MIT",
  "author": "Hayden Bleasel",
  "type": "module",
  "scripts": {
    "dev": "remotion studio",
    "studio": "remotion studio",
    "render": "remotion render BatchworkLaunch out/batchwork-launch.mp4",
    "render:embeddings": "remotion render BatchworkEmbeddings out/batchwork-embeddings.mp4",
    "render:images": "remotion render BatchworkImages out/batchwork-images.mp4",
    "still": "remotion still BatchworkLaunch out/still.png",
    "still:embeddings": "remotion still BatchworkEmbeddings out/embeddings-still.png",
    "still:images": "remotion still BatchworkImages out/images-still.png",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.484",
    "@remotion/google-fonts": "4.0.484",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "4.0.484"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^7.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}

{
  "name": "batchwork",
  "version": "0.0.0",
  "description": "The missing batch API for the Vercel AI SDK — unified, low-cost LLM batch processing across providers.",
  "keywords": [
    "ai",
    "ai-sdk",
    "anthropic",
    "batch",
    "llm",
    "openai",
    "vercel"
  ],
  "license": "MIT",
  "author": "Hayden Bleasel",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run scripts/build.ts --watch",
    "typecheck": "tsgo --noEmit && tsgo --noEmit -p tsconfig.bun.json",
    "test": "bun test"
  },
  "dependencies": {
    "ai": "^6.0.204"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/openai": "^3.0.71",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "^7.0.0-dev.20260613.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=3",
    "@ai-sdk/openai": ">=3"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    }
  }
}

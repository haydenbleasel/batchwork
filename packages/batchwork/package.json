{
  "name": "batchwork",
  "version": "0.0.0",
  "description": "The missing batch API for the Vercel AI SDK — unified, low-cost LLM batch processing across providers.",
  "keywords": [
    "ai",
    "ai-sdk",
    "anthropic",
    "batch",
    "llm",
    "openai",
    "vercel"
  ],
  "license": "MIT",
  "author": "Hayden Bleasel",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ai": "^6.0.204"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/openai": "^3.0.71",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "^7.0.0-dev.20260613.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=3",
    "@ai-sdk/openai": ">=3"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    }
  }
}

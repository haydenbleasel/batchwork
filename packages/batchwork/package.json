{
  "name": "batchwork",
  "version": "0.0.0",
  "description": "The missing batch API for the Vercel AI SDK — unified, low-cost LLM batch processing across providers.",
  "keywords": [
    "ai",
    "ai-sdk",
    "anthropic",
    "batch",
    "llm",
    "openai",
    "vercel"
  ],
  "license": "MIT",
  "author": "Hayden Bleasel",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    },
    "./pool": {
      "types": "./dist/pool/index.d.ts",
      "import": "./dist/pool/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run scripts/build.ts --watch",
    "typecheck": "tsgo --noEmit && tsgo --noEmit -p tsconfig.bun.json",
    "test": "bun test ./test",
    "test:coverage": "bun test ./test --coverage",
    "test:live": "bun test --env-file=.env.local ./live"
  },
  "dependencies": {
    "ai": "^6.0.204"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/groq": "^3.0.41",
    "@ai-sdk/mistral": "^3.0.39",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/togetherai": "^2.0.55",
    "@ai-sdk/xai": "^3.0.95",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "^7.0.0-dev.20260613.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=3",
    "@ai-sdk/google": ">=3",
    "@ai-sdk/groq": ">=3",
    "@ai-sdk/mistral": ">=3",
    "@ai-sdk/openai": ">=3",
    "@ai-sdk/togetherai": ">=2",
    "@ai-sdk/xai": ">=3"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/groq": {
      "optional": true
    },
    "@ai-sdk/mistral": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/togetherai": {
      "optional": true
    },
    "@ai-sdk/xai": {
      "optional": true
    }
  }
}

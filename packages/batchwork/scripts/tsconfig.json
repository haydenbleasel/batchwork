{
  // Bun-typed typecheck config for the build tooling. scripts/build.ts uses
  // Bun.build / Bun.spawn, so it needs @types/bun. Kept separate from the
  // library typecheck so Bun-only globals (e.g. Bun's wider `fetch`) never leak
  // into src/.
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["bun"]
  },
  "include": ["**/*"]
}

{
  // Library typecheck config (`tsgo --noEmit`). Kept on standard/Node types so
  // the published surface reflects the standard runtime (e.g. a plain `fetch`),
  // not Bun's. The published build is produced by scripts/build.ts (Bun for .js
  // + tsgo for .d.ts, via tsconfig.build.json); the Bun-typed build tooling is
  // typechecked separately via scripts/tsconfig.json.
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"],
    "strictNullChecks": true
  },
  "include": ["src", "test", "examples", "vitest.config.ts"]
}

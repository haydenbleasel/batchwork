# Credentials for the live provider tests (see live/README.md).
# Copy to `.env.local` and fill in the keys you have — each provider's test is
# skipped unless its key is set, so you only need the ones you want to run.
# The `test:live` script loads this file via `--env-file` (bun test runs with
# NODE_ENV=test, which skips auto-loading `.env.local`).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Google accepts either of these:
GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=

# --- Store adapter tests (live/postgres.live.test.ts, live/redis.live.test.ts) ---
# Each store's live test is skipped unless its credentials are set.

# Postgres (any node-postgres-compatible connection string).
DATABASE_URL=
# Upstash Redis REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional tuning (defaults shown) ---

# How long to wait for a batch before giving up.
# BATCHWORK_LIVE_TIMEOUT_MS=1800000
# Delay between status polls.
# BATCHWORK_LIVE_POLL_MS=10000

# Override the model id per provider.
# BATCHWORK_LIVE_OPENAI_MODEL=gpt-4o-mini
# BATCHWORK_LIVE_ANTHROPIC_MODEL=claude-haiku-4-5
# BATCHWORK_LIVE_GOOGLE_MODEL=gemini-2.5-flash
# BATCHWORK_LIVE_GROQ_MODEL=llama-3.1-8b-instant
# BATCHWORK_LIVE_MISTRAL_MODEL=mistral-small-latest
# BATCHWORK_LIVE_TOGETHER_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo
# BATCHWORK_LIVE_XAI_MODEL=grok-3-mini

---
import PageLayout from "blume/components/layout/PageLayout.astro";
import data from "blume:data";
import "../styles/home.css";

import FeatureSections from "../components/home/feature-sections.astro";
import Footer from "../components/home/footer.astro";
import Hero from "../components/home/hero.astro";
import { getLatestVersion, getReleaseUrl } from "../lib/latest-version";

const { config } = data;
const version = await getLatestVersion();
const releaseUrl = getReleaseUrl(version);
---

<PageLayout
  site={{ title: config.title, description: config.description }}
  logo={config.logo}
  banner={config.banner}
  analytics={config.analytics}
  navigation={data.navigation}
  favicon={config.favicon}
  fontCssVars={data.fontCssVars}
  themeMode={config.theme.mode}
  searchEnabled={config.search.enabled}
  siteUrl={config.site}
  ogEnabled={config.og.enabled}
  ogImage="/opengraph-image.png"
  page={{
    title: "Save up to 50% on LLM costs | Batchwork",
    description: config.description,
  }}
>
  <Hero releaseUrl={releaseUrl} version={version} />
  <FeatureSections />
  <Footer slot="footer" />
</PageLayout>

{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["topo"]
    },
    "test": {
      "dependsOn": ["topo"]
    },
    "lint": {
      "dependsOn": ["topo"]
    }
  }
}
